# Copier en .env et remplir les valeurs

# URL du site en production
SITE_URL=https://dmulti-services.fr

# Web3Forms — obtenir une clé sur https://web3forms.com
WEB3FORMS_KEY=votre-cle-web3forms

# Umami Analytics — créé lors du déploiement (wf-10)
UMAMI_WEBSITE_ID=

# Keystatic Cloud — pour le mode CMS (optionnel)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
