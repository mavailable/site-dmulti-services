---
import { getContactSection, getSiteInfo } from '@data/content';
const contact = getContactSection();
const siteInfo = getSiteInfo();

const WEB3FORMS_KEY = '4708454a-b5bc-4745-9315-f1d3ac612cde';
---

<form
  id="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
  novalidate
>
  <!-- Web3Forms config -->
  <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
  <input type="hidden" name="redirect" value="https://dmultiservices.fr/merci" />
  <input type="hidden" name="from_name" value="DMulti Services" />
  <input type="hidden" name="subject" value="Nouveau devis depuis dmultiservices.fr" />
  <input type="hidden" name="replyto" value="$email" />

  <!-- Notification à l'agence -->
  <input type="hidden" name="cc" value="marc@muller.im" />

  <!-- Honeypot anti-spam (OBLIGATOIRE) -->
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    style="display:none;"
    tabindex="-1"
    aria-hidden="true"
  />

  <!-- Nom -->
  <div>
    <label for="cf-name" class="block text-sm font-medium text-neutral-700 mb-1.5">
      Votre nom <span class="text-red-500" aria-label="champ obligatoire">*</span>
    </label>
    <input
      type="text"
      id="cf-name"
      name="name"
      required
      autocomplete="name"
      aria-required="true"
      class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-neutral-900 placeholder-neutral-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/20 outline-none transition-all text-sm"
      placeholder="Jean Dupont"
    />
  </div>

  <!-- Téléphone -->
  <div>
    <label for="cf-phone" class="block text-sm font-medium text-neutral-700 mb-1.5">
      Votre téléphone <span class="text-red-500" aria-label="champ obligatoire">*</span>
    </label>
    <input
      type="tel"
      id="cf-phone"
      name="phone"
      required
      autocomplete="tel"
      aria-required="true"
      class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-neutral-900 placeholder-neutral-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/20 outline-none transition-all text-sm"
      placeholder="06 XX XX XX XX"
    />
  </div>

  <!-- Email (optionnel) -->
  <div>
    <label for="cf-email" class="block text-sm font-medium text-neutral-700 mb-1.5">
      Votre e-mail <span class="text-neutral-400 text-xs font-normal">(optionnel)</span>
    </label>
    <input
      type="email"
      id="cf-email"
      name="email"
      autocomplete="email"
      class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-neutral-900 placeholder-neutral-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/20 outline-none transition-all text-sm"
      placeholder="jean.dupont@exemple.fr"
    />
  </div>

  <!-- Message -->
  <div>
    <label for="cf-message" class="block text-sm font-medium text-neutral-700 mb-1.5">
      Décrivez votre projet <span class="text-red-500" aria-label="champ obligatoire">*</span>
    </label>
    <textarea
      id="cf-message"
      name="message"
      required
      rows="4"
      aria-required="true"
      class="w-full px-4 py-3 rounded-xl border border-neutral-200 text-neutral-900 placeholder-neutral-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/20 outline-none transition-all text-sm resize-none"
      placeholder="Type de travaux, surface approximative, délai souhaité, commune..."
    ></textarea>
  </div>

  <!-- Message d'erreur aria-live -->
  <div
    id="form-error"
    role="alert"
    aria-live="polite"
    class="hidden text-red-600 text-sm p-3 bg-red-50 rounded-lg border border-red-200"
  ></div>

  <!-- Mention RGPD -->
  <p class="text-neutral-400 text-xs leading-relaxed">
    {contact.rgpdText}{' '}
    <a href="/politique-de-confidentialite" class="underline hover:text-neutral-600 transition-colors">
      Politique de confidentialité
    </a>.
  </p>

  <!-- Submit -->
  <button
    type="submit"
    id="form-submit"
    class="w-full inline-flex items-center justify-center gap-2 bg-accent-500 text-primary-900 font-bold py-4 rounded-full hover:bg-accent-600 transition-all duration-200 shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)] hover:shadow-[0_6px_18px_0_rgb(240_168_0_/_0.45)] min-h-[52px] disabled:opacity-70 disabled:cursor-not-allowed"
  >
    <svg
      id="submit-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
    </svg>
    <span id="submit-text">{contact.submitButtonText}</span>
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text') as HTMLSpanElement;
  const submitIcon = document.getElementById('submit-icon') as SVGElement;
  const errorBox = document.getElementById('form-error') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset error
    errorBox.classList.add('hidden');
    errorBox.textContent = '';

    // Désactiver le bouton pendant l'envoi
    submitBtn.disabled = true;
    submitText.textContent = 'Envoi en cours...';
    submitIcon.innerHTML = '<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z" opacity=".3"/><path d="M12 4V2a10 10 0 0 0-10 10h2A8 8 0 0 1 12 4z" class="animate-spin origin-center"/>';

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        // Tracker la conversion dans Umami
        if (typeof (window as any).umami !== 'undefined') {
          (window as any).umami.track('form-submit', { page: window.location.pathname });
        }
        // Redirect vers /merci
        window.location.href = '/merci';
      } else {
        throw new Error(json.message ?? 'Erreur lors de l\'envoi.');
      }
    } catch (err) {
      errorBox.textContent = (err as Error).message ?? 'Une erreur est survenue. Appelez directement David au 06 08 46 57 47.';
      errorBox.classList.remove('hidden');
      submitBtn.disabled = false;
      submitText.textContent = 'Envoyer ma demande';
    }
  });
</script>
