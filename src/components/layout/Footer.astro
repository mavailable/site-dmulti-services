---
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();
const year = new Date().getFullYear();
---

<footer class="bg-primary-950 text-neutral-300" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-8 border-b border-primary-800">

      <!-- Identité -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <picture>
            <source srcset="/images/logo-emblem.webp" type="image/webp" />
            <img src="/images/logo-emblem-small.png" alt="" width="40" height="40" aria-hidden="true" class="w-10 h-10" loading="lazy" decoding="async" />
          </picture>
          <span class="font-heading font-bold text-white text-lg">
            DMulti <span class="text-accent-400">Services</span>
          </span>
        </div>
        <p class="text-sm text-neutral-400 leading-relaxed">
          Artisan multi-services à Laslades (65).<br/>
          Menuiserie, cuisine, terrasses bois, sols, peinture.
        </p>
        <!-- Facebook -->
        {siteInfo.facebook && (
          <a
            href={siteInfo.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-4 text-neutral-400 hover:text-accent-400 transition-colors text-sm"
            aria-label="DMulti Services sur Facebook (ouvre dans un nouvel onglet)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        )}
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contact</h3>
        <address class="not-italic text-sm space-y-2 text-neutral-400">
          <p>
            <a
              href={siteInfo.whatsapp ? `https://wa.me/${siteInfo.phone.replace('+', '')}` : `tel:${siteInfo.phone}`}
              target={siteInfo.whatsapp ? '_blank' : undefined}
              rel={siteInfo.whatsapp ? 'noopener noreferrer' : undefined}
              class="hover:text-accent-400 transition-colors flex items-center gap-2"
              aria-label={siteInfo.whatsapp ? `Contacter David sur WhatsApp` : `Appeler le ${siteInfo.phoneFormatted}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              {siteInfo.phoneFormatted}
              {siteInfo.whatsapp && <span class="text-xs text-green-400">(WhatsApp)</span>}
            </a>
          </p>
          {siteInfo.email && (
            <p>
              <a
                href="#contact"
                class="hover:text-accent-400 transition-colors flex items-center gap-2"
                aria-label="Envoyer un message via le formulaire de contact"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
                Formulaire de contact
              </a>
            </p>
          )}
          <p class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 mt-0.5" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span>{siteInfo.address}, {siteInfo.postalCode} {siteInfo.city}</span>
          </p>
          <p class="text-xs text-neutral-500 mt-1">
            Zone : {siteInfo.zones.slice(0, 2).join(' · ')}
          </p>
        </address>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Navigation</h3>
        <nav aria-label="Liens du pied de page">
          <ul class="space-y-2 text-sm">
            <li><a href="#services" class="text-neutral-400 hover:text-accent-400 transition-colors">Services</a></li>
            <li><a href="#realisations" class="text-neutral-400 hover:text-accent-400 transition-colors">Réalisations</a></li>
            <li><a href="#a-propos" class="text-neutral-400 hover:text-accent-400 transition-colors">À propos</a></li>
            <li><a href="#faq" class="text-neutral-400 hover:text-accent-400 transition-colors">FAQ</a></li>
            <li><a href="#contact" class="text-neutral-400 hover:text-accent-400 transition-colors">Contact</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- Copyright + liens légaux -->
    <div class="pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-neutral-500">
      <p>© {year} {siteInfo.name} — Artisan multi-services à {siteInfo.city} ({siteInfo.postalCode.slice(0,2)}). Tous droits réservés.</p>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales" class="hover:text-neutral-300 transition-colors">Mentions légales</a>
        <a href="/politique-de-confidentialite" class="hover:text-neutral-300 transition-colors">Confidentialité</a>
        <span class="text-neutral-700">·</span>
        <a href="https://marcm.fr/100-sites-artisans/" class="text-neutral-500 hover:text-neutral-400 transition-colors">Site réalisé par Marc M. · Spécialiste sites web pour artisans</a>
      </div>
    </div>
  </div>
</footer>
