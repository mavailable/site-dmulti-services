---
// Galerie réalisations avec filtres par métier
// Photos dans public/images/realisations/{categorie}/

const categories = [
  { id: 'tous',           label: 'Tout voir',         count: 59 },
  { id: 'terrasse',       label: 'Terrasses bois',    count: 11 },
  { id: 'cuisine',        label: 'Cuisines',          count: 15 },
  { id: 'sol',            label: 'Sols & parquets',   count: 13 },
  { id: 'salle-de-bain',  label: 'Salles de bain',    count: 6  },
  { id: 'menuiserie',     label: 'Menuiserie',        count: 5  },
  { id: 'peinture',       label: 'Peinture',          count: 8  },
];

const DEFAULT_CAT = 'terrasse'; // affiché au départ
const SHOW_ALL_LIMIT = 12;      // max photos pour "Tout voir" avant "Voir plus"

const catAlts: Record<string, string> = {
  cuisine:          'Pose de cuisine équipée par DMulti Services',
  terrasse:         'Terrasse bois posée par DMulti Services',
  sol:              'Revêtement de sol par DMulti Services',
  'salle-de-bain':  'Rénovation salle de bain par DMulti Services',
  menuiserie:       'Menuiserie par DMulti Services',
  peinture:         'Peinture et enduits par DMulti Services',
  autre:            'Réalisation DMulti Services',
};

const catCounts: Record<string, number> = {
  cuisine: 15, terrasse: 11, sol: 13,
  'salle-de-bain': 6, menuiserie: 5, peinture: 8, autre: 1,
};

interface Photo { src: string; webp: string; alt: string; cat: string; idx: number }
const photos: Photo[] = [];
for (const [cat, count] of Object.entries(catCounts)) {
  for (let i = 1; i <= count; i++) {
    const base = `/images/realisations/${cat}/${cat}-${String(i).padStart(2,'0')}`;
    photos.push({
      src:  `${base}.jpg`,
      webp: `${base}.webp`,
      alt: `${catAlts[cat]} — photo ${i}`,
      cat,
      idx: i - 1,
    });
  }
}
---

<!-- Section Réalisations — fond primary-900 (sombre) -->
<section
  id="realisations"
  class="bg-primary-900 py-20 lg:py-28"
  aria-labelledby="gallery-title"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- En-tête -->
    <div class="text-center mb-10">
      <p class="text-accent-400 font-semibold text-sm uppercase tracking-widest mb-3">Portfolio</p>
      <h2 id="gallery-title" class="font-heading font-bold text-white text-3xl sm:text-4xl mb-4">
        Nos réalisations
      </h2>
      <p class="text-neutral-300 text-lg max-w-2xl mx-auto">
        Chaque chantier est une nouvelle réalisation soignée. Découvrez quelques-uns des travaux réalisés dans les Hautes-Pyrénées et le Gers.
      </p>
    </div>

    <!-- Filtres par métier -->
    <div class="flex flex-wrap gap-2 justify-center mb-10" role="tablist" aria-label="Filtrer par métier">
      {categories.map((cat) => (
        <button
          type="button"
          role="tab"
          aria-selected={cat.id === DEFAULT_CAT ? 'true' : 'false'}
          data-filter={cat.id}
          class={`gallery-filter px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border ${
            cat.id === DEFAULT_CAT
              ? 'bg-accent-500 text-primary-900 border-accent-500'
              : 'bg-transparent text-neutral-300 border-white/20 hover:border-accent-400 hover:text-accent-400'
          }`}
        >
          {cat.label}
          <span class="ml-1 text-xs opacity-60">({cat.count})</span>
        </button>
      ))}
    </div>

    <!-- Grille photos -->
    <ul
      id="gallery-grid"
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 list-none"
      role="list"
      aria-label="Galerie de réalisations"
    >
      {photos.map((photo, i) => {
        const isDefault = photo.cat === DEFAULT_CAT;
        // Toutes les images galerie sont SOUS LE FOLD — toujours lazy
        // Les images non-default utilisent data-src pour ne même pas être initialisées
        return (
        <li
          data-cat={photo.cat}
          data-i={photo.idx}
          class="gallery-item"
          style={!isDefault ? 'display:none' : ''}
        >
          <figure class="relative overflow-hidden rounded-xl aspect-[4/3] bg-primary-800 group">
            <picture>
              {isDefault
                ? <source type="image/webp" srcset={photo.webp} />
                : <source type="image/webp" data-srcset={photo.webp} />
              }
              <img
                src={isDefault ? photo.src : undefined}
                data-src={!isDefault ? photo.src : undefined}
                alt={photo.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
                width="400"
                height="300"
              />
            </picture>
            <figcaption class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-primary-950/70 to-transparent px-3 py-2 translate-y-full group-hover:translate-y-0 transition-transform duration-200">
              <span class="text-white text-xs font-medium capitalize">{photo.cat.replace('-', ' ')}</span>
            </figcaption>
          </figure>
        </li>
        );
      })}
    </ul>

    <!-- Bouton "Voir plus" (masqué par défaut, géré en JS) -->
    <div id="gallery-more-wrap" class="text-center mt-6 hidden">
      <button
        id="gallery-more-btn"
        type="button"
        class="inline-flex items-center gap-2 border-2 border-accent-500/50 text-accent-400 font-semibold px-6 py-3 rounded-full hover:border-accent-500 hover:text-accent-300 transition-colors text-sm"
      >
        Voir plus de photos
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </button>
    </div>

    <!-- Lien Facebook -->
    <div class="text-center mt-8">
      <a
        href="https://www.facebook.com/profile.php?id=100066445609602"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border-2 border-white/30 text-neutral-300 font-medium px-6 py-3 rounded-full hover:border-white hover:text-white transition-colors"
        aria-label="Voir toutes les réalisations sur Facebook (ouvre dans un nouvel onglet)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Voir plus de réalisations sur Facebook
      </a>
    </div>
  </div>
</section>

<script>
  const SHOW_ALL_LIMIT = 12;

  const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.gallery-filter');
  const items       = document.querySelectorAll<HTMLElement>('.gallery-item');
  const moreWrap    = document.getElementById('gallery-more-wrap') as HTMLElement;
  const moreBtn     = document.getElementById('gallery-more-btn') as HTMLButtonElement;

  let currentFilter = 'terrasse';
  let showAll = false;

  function applyFilter(cat: string, expandAll = false) {
    currentFilter = cat;
    showAll = expandAll;

    // Boutons onglets
    filterBtns.forEach(b => {
      const active = b.dataset.filter === cat;
      b.setAttribute('aria-selected', active ? 'true' : 'false');
      if (active) {
        b.classList.add('bg-accent-500', 'text-primary-900', 'border-accent-500');
        b.classList.remove('bg-transparent', 'text-neutral-300', 'border-white/20');
      } else {
        b.classList.remove('bg-accent-500', 'text-primary-900', 'border-accent-500');
        b.classList.add('bg-transparent', 'text-neutral-300', 'border-white/20');
      }
    });

    // Affichage photos + lazy-load: swap data-src → src au moment du reveal
    let shown = 0;
    let hidden = 0;
    items.forEach(item => {
      const match = cat === 'tous' || item.dataset.cat === cat;
      if (!match) {
        item.style.display = 'none';
        return;
      }
      if (cat === 'tous' && !showAll && shown >= SHOW_ALL_LIMIT) {
        item.style.display = 'none';
        hidden++;
      } else {
        item.style.display = '';
        shown++;
        // Swap data-src → src et data-srcset → srcset au moment du reveal
        const img = item.querySelector<HTMLImageElement>('img[data-src]');
        if (img?.dataset.src) {
          // Activer la source WebP
          const source = item.querySelector<HTMLSourceElement>('source[data-srcset]');
          if (source?.dataset.srcset) {
            source.srcset = source.dataset.srcset;
            delete source.dataset.srcset;
          }
          img.src = img.dataset.src;
          delete img.dataset.src;
        }
      }
    });

    // Bouton "Voir plus" uniquement pour "Tout voir" tronqué
    if (cat === 'tous' && hidden > 0) {
      moreWrap.classList.remove('hidden');
    } else {
      moreWrap.classList.add('hidden');
    }
  }

  // Filtre par clic sur onglet
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter ?? 'tous', false);
    });
  });

  // Voir plus
  moreBtn.addEventListener('click', () => {
    applyFilter('tous', true);
  });

  // Écoute l'event venant de Services.astro (clic sur une prestation)
  document.addEventListener('gallery:filter', (e: Event) => {
    const filter = (e as CustomEvent<{ filter: string }>).detail.filter;
    applyFilter(filter, false);
  });

  // Vérifie aussi au chargement si un filtre est en attente (depuis un clic Services)
  document.addEventListener('DOMContentLoaded', () => {
    const pending = (window as any).__pendingGalleryFilter;
    if (pending) {
      applyFilter(pending, false);
      (window as any).__pendingGalleryFilter = null;
    }
  });
</script>
