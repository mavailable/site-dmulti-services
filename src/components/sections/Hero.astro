---
import { getSiteInfo, getHero } from '@data/content';
const siteInfo = getSiteInfo();
const hero = getHero();
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-primary-900"
  aria-labelledby="hero-title"
>
  <!-- Image de fond avec overlay -->
  <!-- TODO: Remplacer le gradient par la vraie photo hero (hero-bg.jpg) -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"
    aria-hidden="true"
  >
    <!-- Motif décoratif discret -->
    <div class="absolute inset-0 opacity-5 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC40Ij48cGF0aCBkPSJNMzYgMzRoLTJ2LTJoMnYyem0tNCAwSDMwdi0yaDJ2MnoiLz48L2c+PC9nPjwvc3ZnPg==')]"></div>

    <!-- Accent décoratif doré -->
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-accent-500/5 rounded-full blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-1/4 left-0 w-64 h-64 bg-secondary-500/10 rounded-full blur-3xl" aria-hidden="true"></div>
  </div>

  <!-- Contenu hero -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">

    <!-- Badge accrocheur -->
    <div class="inline-flex items-center gap-2 bg-accent-500/10 border border-accent-500/30 text-accent-400 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-500 animate-pulse"></span>
      Artisan disponible dans les Hautes-Pyrénées & le Gers
    </div>

    <!-- H1 — seul sur toute la page -->
    <h1
      id="hero-title"
      class="font-heading font-extrabold text-white text-3xl sm:text-4xl lg:text-5xl xl:text-6xl leading-tight mb-6"
      data-cms-field="hero.title" data-cms-type="text"
    >
      {hero.title}
    </h1>

    <!-- Sous-titre -->
    <p class="text-neutral-300 text-lg sm:text-xl max-w-3xl mx-auto leading-relaxed mb-10" data-cms-field="hero.subtitle" data-cms-type="text">
      {hero.subtitle}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
      <!-- CTA principal : devis -->
      <a
        href={hero.ctaPrimaryHref}
        data-track="cta"
        class="inline-flex items-center gap-2 bg-accent-500 text-primary-900 font-bold text-base px-8 py-4 rounded-full hover:bg-accent-600 transition-all duration-200 shadow-[0_4px_14px_0_rgb(240_168_0_/_0.45)] hover:shadow-[0_6px_20px_0_rgb(240_168_0_/_0.55)] min-h-[52px] w-full sm:w-auto justify-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
        </svg>
        <span data-cms-field="hero.ctaPrimaryText" data-cms-type="text">{hero.ctaPrimaryText}</span>
      </a>

      <!-- CTA secondaire : appel -->
      <a
        href={hero.ctaSecondaryHref}
        class="inline-flex items-center gap-2 border-2 border-white/50 text-white font-semibold text-base px-8 py-4 rounded-full hover:bg-white/10 hover:border-white transition-all duration-200 min-h-[52px] w-full sm:w-auto justify-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <span data-cms-field="hero.ctaSecondaryText" data-cms-type="text">{hero.ctaSecondaryText}</span>
      </a>
    </div>

    <!-- Réassurance -->
    <p class="text-neutral-400 text-sm flex items-center justify-center gap-2 flex-wrap" data-cms-field="hero.trustBadge" data-cms-type="text">
      {hero.trustBadge.split(' · ').map((item, i, arr) => (
        <>
          <span>{item}</span>
          {i < arr.length - 1 && <span class="text-accent-500/50" aria-hidden="true">·</span>}
        </>
      ))}
    </p>
  </div>

  <!-- Flèche scroll bas -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/90">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>
