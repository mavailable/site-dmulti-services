---
import { getContactSection, getSiteInfo } from '@data/content';
import ContactForm from '@components/forms/ContactForm.astro';
const contact = getContactSection();
const siteInfo = getSiteInfo();
---

<!-- Section Contact — fond neutral-50 (clair), formulaire + coordonnées -->
<section
  id="contact"
  class="bg-neutral-50 py-20 lg:py-28"
  aria-labelledby="contact-title"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

      <!-- Colonne gauche : info + coordonnées -->
      <div>
        <p class="text-secondary-700 font-semibold text-sm uppercase tracking-widest mb-3">Contact</p>
        <h2 id="contact-title" class="font-heading font-bold text-primary-900 text-3xl sm:text-4xl mb-4">
          {contact.title}
        </h2>
        <p class="text-neutral-700 text-lg mb-8">{contact.subtitle}</p>

        <!-- Coordonnées directes -->
        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-accent-500/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-accent-700" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <p class="text-neutral-700 text-xs font-medium uppercase tracking-wide mb-1">Téléphone / WhatsApp</p>
              <a
                href={`tel:${siteInfo.phone}`}
                class="text-primary-900 font-bold text-xl hover:text-secondary-600 transition-colors"
              >
                {siteInfo.phoneFormatted}
              </a>
              <p class="text-neutral-700 text-sm mt-0.5">Réponse rapide par appel ou message</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-accent-500/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-accent-700" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </div>
            <div>
              <p class="text-neutral-700 text-xs font-medium uppercase tracking-wide mb-1">Localisation</p>
              <p class="text-primary-900 font-semibold">{siteInfo.address}, {siteInfo.postalCode} {siteInfo.city}</p>
              <p class="text-neutral-700 text-sm mt-0.5">Zone : {siteInfo.zones.slice(0, 4).join(', ')}</p>
            </div>
          </div>
        </div>

        <!-- Badge réassurance -->
        <div class="mt-8 p-4 bg-white rounded-xl border border-neutral-200 flex items-center gap-3">
          <span class="text-2xl" aria-hidden="true">✅</span>
          <p class="text-neutral-700 text-sm leading-relaxed">
            <strong class="text-primary-900">Devis gratuit et sans engagement</strong><br/>
            David vous répond dans la journée.
          </p>
        </div>
      </div>

      <!-- Colonne droite : formulaire Web3Forms -->
      <div>
        <!-- Bouton WhatsApp -->
        {siteInfo.whatsapp && (
          <a
            href={`https://wa.me/${siteInfo.phone.replace('+', '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full bg-[#19773e] hover:bg-[#155e30] text-white font-semibold text-base py-4 rounded-2xl mb-4 transition-colors duration-200 shadow-sm"
            aria-label="Contacter David sur WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Envoyer un message WhatsApp
          </a>
          <p class="text-center text-neutral-700 text-xs mb-4">— ou remplissez le formulaire —</p>
        )}

        <div class="bg-white rounded-2xl shadow-[0_1px_3px_0_rgb(0_0_0_/_0.1)] p-8">
          <h3 class="font-heading font-bold text-primary-900 text-xl mb-6">Décrivez votre projet</h3>
          <ContactForm />
        </div>
      </div>
    </div>
  </div>
</section>
