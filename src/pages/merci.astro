---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();
---

<BaseLayout
  title="Merci pour votre message — DMulti Services"
  description="David a bien reçu votre demande et vous recontactera dans les plus brefs délais."
  canonicalUrl="https://dmultiservices.fr/merci"
  noIndex={true}
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <main id="main-content" class="min-h-screen bg-neutral-50 flex items-center justify-center px-4 py-32">
    <div class="text-center max-w-lg">

      <!-- Icône succès -->
      <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-green-600" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
      </div>

      <h1 class="font-heading font-bold text-primary-900 text-3xl sm:text-4xl mb-4">
        Merci pour votre message !
      </h1>
      <p class="text-neutral-600 text-lg mb-8 leading-relaxed">
        David a bien reçu votre demande et vous recontactera dans les plus brefs délais.
        En attendant, vous pouvez découvrir ses dernières réalisations sur Facebook.
      </p>

      <!-- CTAs secondaires -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-accent-500 text-primary-900 font-bold px-6 py-3 rounded-full hover:bg-accent-600 transition-all min-h-[44px] shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
          </svg>
          Retour à l'accueil
        </a>
        <a
          href={siteInfo.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary-200 text-primary-700 font-semibold px-6 py-3 rounded-full hover:bg-primary-50 transition-colors min-h-[44px]"
          aria-label="Voir les réalisations sur Facebook (ouvre dans un nouvel onglet)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Nos réalisations sur Facebook
        </a>
      </div>

      <!-- Rappel contact direct -->
      <p class="mt-8 text-neutral-500 text-sm">
        Besoin de parler à David de suite ?{' '}
        <a href={`tel:${siteInfo.phone}`} class="font-semibold text-primary-900 hover:text-secondary-600 transition-colors">
          {siteInfo.phoneFormatted}
        </a>
      </p>
    </div>
  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>

<script>
  // Track conversion event on /merci page
  if (typeof (window as any).umami !== 'undefined') {
    (window as any).umami.track('conversion', { type: 'form-submit', page: '/merci' });
  }
</script>
