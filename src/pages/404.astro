---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();
---

<BaseLayout
  title="Page introuvable — DMulti Services"
  description="La page demandée n'existe pas. Retournez à l'accueil pour trouver ce que vous cherchez."
  noIndex={true}
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <main id="main-content" class="min-h-screen bg-neutral-50 flex items-center justify-center px-4 py-32">
    <div class="text-center max-w-lg">

      <!-- 404 decoratif -->
      <div class="font-heading font-extrabold text-primary-100 text-9xl leading-none select-none mb-4" aria-hidden="true">
        404
      </div>

      <h1 class="font-heading font-bold text-primary-900 text-3xl sm:text-4xl mb-4">
        Cette page n'existe pas
      </h1>
      <p class="text-neutral-600 text-lg mb-8 leading-relaxed">
        Oups, la page que vous cherchez est introuvable. Elle a peut-être été déplacée ou supprimée.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-accent-500 text-primary-900 font-bold px-6 py-3 rounded-full hover:bg-accent-600 transition-all min-h-[44px] shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
          </svg>
          Retour à l'accueil
        </a>
        <a
          href="/#contact"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary-200 text-primary-700 font-semibold px-6 py-3 rounded-full hover:bg-primary-50 transition-colors min-h-[44px]"
        >
          Nous contacter
        </a>
      </div>

      <!-- Contact direct -->
      <p class="mt-8 text-neutral-500 text-sm">
        Ou appelez directement David :{' '}
        <a href={`tel:${siteInfo.phone}`} class="font-semibold text-primary-900 hover:text-secondary-600 transition-colors">
          {siteInfo.phoneFormatted}
        </a>
      </p>
    </div>
  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>

<script>
  // Track 404 error in Umami
  if (typeof (window as any).umami !== 'undefined') {
    (window as any).umami.track('404_error', { path: window.location.pathname });
  }
</script>
