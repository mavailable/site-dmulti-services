---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';

const keystaticBase = 'https://dmultiservices.fr/keystatic';
const umamiShareUrl = 'https://cloud.umami.is/share/JjfNrReGhEwGVgjs';
const googleBusinessUrl = 'https://www.google.com/maps/place/DMulti+services/@43.3939781,0.1839699,17z';
const googleReviewLink = 'https://g.page/r/CT-uf4cbQ6Wf/review';

const collections = [
  {
    slug: 'services',
    name: 'Prestations',
    count: 7,
    fields: ['Titre', 'Description', 'Icone', 'Image'],
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>`,
  },
  {
    slug: 'testimonials',
    name: 'Temoignages',
    count: 3,
    fields: ['Auteur', 'Ville', 'Prestation', 'Texte'],
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>`,
  },
  {
    slug: 'faq',
    name: 'Questions frequentes',
    count: 5,
    fields: ['Question', 'Reponse'],
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
  },
];

const singletons = [
  { slug: 'siteInfo', name: 'Informations generales', description: 'Nom, telephone, email, adresse, zones', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>` },
  { slug: 'hero', name: 'Section Hero', description: 'Titre, sous-titre, boutons', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>` },
  { slug: 'about', name: 'Section A propos', description: 'Texte, photo, chiffres cles', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>` },
  { slug: 'contact', name: 'Section Contact', description: 'Titre, sous-titre, texte RGPD', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>` },
];
---

<BaseLayout
  title="Espace prive — David"
  description="Dashboard de gestion du site DMulti Services"
  noIndex={true}
>
  <!-- Barre sticky de navigation -->
  <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-neutral-200">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
      <div class="flex items-center gap-2 overflow-x-auto">
        <button class="tab-btn shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-colors text-accent-700 bg-accent-50" data-tab="0">
          Modifier le site
        </button>
        <button class="tab-btn shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-colors text-neutral-500" data-tab="1">
          Fiche Google
        </button>
        <button class="tab-btn shrink-0 px-4 py-2 rounded-lg text-sm font-semibold transition-colors text-neutral-500" data-tab="2">
          Statistiques
        </button>
      </div>
      <span class="hidden sm:block text-sm text-neutral-400 shrink-0">David</span>
    </div>
  </nav>

  <!-- Container swipeable -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="scrollbar-width: none;">

    <!-- Panel 1 : Modifier le site -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 py-8 md:py-12">

        <div class="mb-10">
          <h1 class="font-heading font-bold text-2xl md:text-3xl text-primary-900">Modifier le site</h1>
          <p class="mt-3 text-neutral-700 max-w-2xl">
            Depuis cette page, vous pouvez modifier le contenu de votre site en 3 etapes :
          </p>
          <ol class="mt-3 text-neutral-700 text-sm space-y-1 list-decimal list-inside">
            <li>Cliquez sur la rubrique a modifier ci-dessous</li>
            <li>Modifiez le texte ou les images dans l'editeur</li>
            <li>Cliquez sur <strong class="text-primary-900">Save</strong> pour enregistrer</li>
          </ol>
          <div class="mt-5">
            <a
              href={keystaticBase}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-primary-900 font-bold px-5 py-2.5 rounded-full transition-colors text-sm shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)]"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
              Modifier mes contenus
            </a>
          </div>
        </div>

        <!-- Collections -->
        <div class="mb-10">
          <h2 class="font-heading font-semibold text-lg text-primary-900 mb-4">Contenus modifiables</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {collections.map((col) => (
              <a
                href={`${keystaticBase}/collection/${col.slug}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-4 p-5 bg-white border border-neutral-200 rounded-xl hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
              >
                <div class="w-11 h-11 rounded-xl bg-accent-500/10 text-accent-700 flex items-center justify-center shrink-0 group-hover:bg-accent-500/20 transition-colors" set:html={col.icon} />
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-heading font-bold text-primary-900">{col.name}</h3>
                    <span class="text-xs bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded-full">{col.count}</span>
                  </div>
                  <div class="flex flex-wrap gap-1 mb-2">
                    {col.fields.map((f) => (
                      <span class="text-xs text-neutral-500 bg-neutral-50 border border-neutral-200 px-1.5 py-0.5 rounded">{f}</span>
                    ))}
                  </div>
                  <span class="inline-flex items-center gap-1 text-xs text-accent-700 bg-accent-50 px-2 py-0.5 rounded-full">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Ajout & suppression possibles
                  </span>
                </div>
                <svg class="w-5 h-5 text-neutral-300 group-hover:text-accent-500 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Singletons -->
        <div class="mb-10">
          <h2 class="font-heading font-semibold text-lg text-primary-900 mb-4">Sections du site</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {singletons.map((s) => (
              <a
                href={`${keystaticBase}/singleton/${s.slug}`}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 p-4 bg-white border border-neutral-200 rounded-xl hover:shadow-sm hover:border-secondary-300 transition-all duration-200"
              >
                <div class="w-9 h-9 rounded-lg bg-secondary-100 text-secondary-600 flex items-center justify-center shrink-0" set:html={s.icon} />
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-sm text-primary-900">{s.name}</h3>
                  <p class="text-xs text-neutral-500">{s.description}</p>
                </div>
                <span class="text-xs text-secondary-600 bg-secondary-50 px-2 py-0.5 rounded-full shrink-0">Modification</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Conseils -->
        <div class="bg-accent-50 border border-accent-200 rounded-xl p-5">
          <h3 class="font-heading font-semibold text-sm text-primary-900 mb-2">Conseils</h3>
          <ul class="text-sm text-neutral-700 space-y-1.5">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              Cliquez sur <strong>Save</strong> en haut a droite apres chaque modification
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              En cas d'erreur, vous pouvez annuler avec le bouton <strong>Reset changes</strong>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              Besoin d'aide ? Contactez <a href="mailto:marc@marc-muller.com" class="underline text-accent-700 font-medium">marc@marc-muller.com</a>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Panel 2 : Fiche Google -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 py-8 md:py-12">

        <h1 class="font-heading font-bold text-2xl md:text-3xl text-primary-900 mb-8">Fiche Google</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="bg-white border border-neutral-200 rounded-xl p-6">
            <div class="w-12 h-12 rounded-xl bg-accent-500/10 text-accent-700 flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <h2 class="font-heading font-bold text-lg text-primary-900 mb-2">Gerer la fiche</h2>
            <p class="text-neutral-700 text-sm mb-5">Modifiez les informations, horaires et photos de votre fiche Google Maps.</p>
            <a
              href={googleBusinessUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-primary-900 font-bold px-5 py-2.5 rounded-full transition-colors text-sm shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)]"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              Voir ma fiche Google
            </a>
          </div>

          <div class="bg-white border border-neutral-200 rounded-xl p-6">
            <div class="w-12 h-12 rounded-xl bg-secondary-100 text-secondary-600 flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            </div>
            <h2 class="font-heading font-bold text-lg text-primary-900 mb-2">Demander un avis</h2>
            <p class="text-neutral-700 text-sm mb-4">Envoyez ce lien a vos clients pour qu'ils laissent un avis Google :</p>
            <div class="flex items-center gap-2">
              <input
                type="text"
                readonly
                value={googleReviewLink}
                id="review-link"
                class="flex-1 px-3 py-2.5 bg-neutral-50 border border-neutral-200 rounded-lg text-sm text-neutral-700 truncate"
              />
              <button
                id="copy-btn"
                class="shrink-0 px-4 py-2.5 bg-secondary-500 hover:bg-secondary-600 text-white font-semibold rounded-lg transition-colors text-sm"
              >
                Copier
              </button>
            </div>
            <p id="copy-feedback" class="text-xs text-accent-600 mt-2 hidden">Lien copie !</p>
          </div>
        </div>

        <div class="bg-accent-50 border border-accent-200 rounded-xl p-5">
          <h3 class="font-heading font-semibold text-sm text-primary-900 mb-2">Astuces pour obtenir plus d'avis</h3>
          <ul class="text-sm text-neutral-700 space-y-1.5">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              Demandez apres un chantier reussi, quand le client est satisfait
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              Envoyez le lien par SMS plutot que par email (meilleur taux de reponse)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-accent-600 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              Repondez toujours aux avis (positifs comme negatifs) pour montrer votre professionnalisme
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Panel 3 : Statistiques -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 py-8 md:py-12">

        <div class="flex items-center justify-between mb-8">
          <h1 class="font-heading font-bold text-2xl md:text-3xl text-primary-900">Statistiques</h1>
          <a
            href={umamiShareUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-accent-700 hover:text-accent-800 font-semibold transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            Ouvrir les statistiques
          </a>
        </div>

        <!-- Desktop : iframe -->
        <div class="hidden md:block">
          <div class="bg-white border border-neutral-200 rounded-xl overflow-hidden">
            <iframe
              src={umamiShareUrl}
              width="100%"
              height="750"
              style="border: none;"
              title="Statistiques du site DMulti Services"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Mobile : lien -->
        <div class="md:hidden">
          <div class="bg-white border border-neutral-200 rounded-xl p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-accent-500/10 text-accent-700 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            <h2 class="font-heading font-bold text-lg text-primary-900 mb-2">Statistiques de votre site</h2>
            <p class="text-neutral-700 text-sm mb-6">Visiteurs, pages vues, sources de trafic... Consultez vos statistiques en temps reel.</p>
            <a
              href={umamiShareUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-primary-900 font-bold px-6 py-3 rounded-full transition-colors text-sm shadow-[0_4px_14px_0_rgb(240_168_0_/_0.35)]"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
              Voir mes statistiques
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer contact webmaster -->
  <footer class="border-t border-neutral-200 bg-neutral-50 py-4">
    <p class="text-center text-sm text-neutral-500">
      Besoin d'aide ? <a href="mailto:marc@marc-muller.com" class="text-accent-700 hover:underline font-medium">marc@marc-muller.com</a>
    </p>
  </footer>
</BaseLayout>

<style is:inline>
  #panels { -ms-overflow-style: none; scrollbar-width: none; }
  #panels::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  const panels = document.getElementById('panels');
  const tabs = document.querySelectorAll('.tab-btn');
  const sections = panels.querySelectorAll('.tab-panel');

  function activateTab(index) {
    tabs.forEach((b, i) => {
      if (i === index) {
        b.classList.remove('text-neutral-500');
        b.classList.add('text-accent-700', 'bg-accent-50');
      } else {
        b.classList.remove('text-accent-700', 'bg-accent-50');
        b.classList.add('text-neutral-500');
      }
    });
  }

  tabs.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      activateTab(i);
    });
  });

  let scrollTimeout;
  panels.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const index = Math.round(panels.scrollLeft / panels.offsetWidth);
      activateTab(index);
    }, 50);
  }, { passive: true });

  const copyBtn = document.getElementById('copy-btn');
  const reviewLink = document.getElementById('review-link');
  const feedback = document.getElementById('copy-feedback');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(reviewLink.value);
      feedback.classList.remove('hidden');
      copyBtn.textContent = 'Copie !';
      setTimeout(() => {
        feedback.classList.add('hidden');
        copyBtn.textContent = 'Copier';
      }, 2000);
    } catch {
      reviewLink.select();
    }
  });
</script>
