---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';
import { legal } from '@data/business';
const siteInfo = getSiteInfo();
const year = new Date().getFullYear();
---

<BaseLayout
  title="Mentions légales — DMulti Services"
  description="Mentions légales du site DMulti Services, artisan multi-services à Laslades (65350), Hautes-Pyrénées."
  canonicalUrl="https://dmulti-services.fr/mentions-legales"
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <main id="main-content" class="bg-neutral-50 py-20 pt-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <nav class="text-sm text-neutral-500 mb-8" aria-label="Fil d'Ariane">
        <ol class="flex items-center gap-2 list-none">
          <li><a href="/" class="hover:text-primary-900 transition-colors">Accueil</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-neutral-700" aria-current="page">Mentions légales</li>
        </ol>
      </nav>

      <article class="bg-white rounded-2xl shadow-[0_1px_3px_0_rgb(0_0_0_/_0.1)] p-8 sm:p-12">
        <h1 class="font-heading font-bold text-primary-900 text-3xl mb-8 pb-6 border-b border-neutral-200">
          Mentions légales
        </h1>

        <div class="prose prose-neutral max-w-none text-neutral-700 leading-relaxed space-y-8">

          <!-- 1. Éditeur du site -->
          <section aria-labelledby="editeur">
            <h2 id="editeur" class="font-heading font-bold text-primary-900 text-xl mb-4">1. Éditeur du site</h2>
            <p>
              Le présent site internet <strong>dmulti-services.fr</strong> est édité par :
            </p>
            <address class="not-italic mt-3 space-y-1 text-sm bg-neutral-50 p-4 rounded-xl border border-neutral-200">
              <p><strong>Nom commercial :</strong> {siteInfo.name}</p>
              <p><strong>Dirigeant :</strong> David</p>
              <p><strong>Activité :</strong> Artisan multi-services bâtiment</p>
              <p><strong>Adresse :</strong> {siteInfo.address}, {siteInfo.postalCode} {siteInfo.city}, France</p>
              <p>
                <strong>Téléphone :</strong>{' '}
                <a href={`tel:${siteInfo.phone}`} class="text-primary-700 hover:underline">{siteInfo.phoneFormatted}</a>
              </p>
              {siteInfo.email && (
                <p>
                  <strong>E-mail :</strong>{' '}
                  <a href={`mailto:${siteInfo.email}`} class="text-primary-700 hover:underline">{siteInfo.email}</a>
                </p>
              )}
              {!siteInfo.email && (
                <p class="text-neutral-400 text-xs italic">E-mail : à compléter</p>
              )}
              {legal.siret ? (
                <p><strong>SIRET :</strong> {legal.siret}</p>
              ) : (
                <p class="text-neutral-400 text-xs italic">SIRET : à compléter avant mise en production</p>
              )}
            </address>
          </section>

          <!-- 2. Directeur de publication -->
          <section aria-labelledby="directeur">
            <h2 id="directeur" class="font-heading font-bold text-primary-900 text-xl mb-4">2. Directeur de la publication</h2>
            <p>
              Le directeur de la publication est <strong>David</strong>, en qualité de dirigeant de DMulti Services.
            </p>
          </section>

          <!-- 3. Hébergeur -->
          <section aria-labelledby="hebergeur">
            <h2 id="hebergeur" class="font-heading font-bold text-primary-900 text-xl mb-4">3. Hébergement</h2>
            <p>Ce site est hébergé par :</p>
            <address class="not-italic mt-3 text-sm bg-neutral-50 p-4 rounded-xl border border-neutral-200 space-y-1">
              <p><strong>Cloudflare Pages</strong></p>
              <p>Cloudflare, Inc.</p>
              <p>101 Townsend St, San Francisco, CA 94107, USA</p>
              <p>Téléphone : +1 (650) 319-8930</p>
              <p>
                <a href="https://www.cloudflare.com" target="_blank" rel="noopener noreferrer" class="text-primary-700 hover:underline">
                  www.cloudflare.com
                </a>
              </p>
            </address>
          </section>

          <!-- 4. Propriété intellectuelle -->
          <section aria-labelledby="pi">
            <h2 id="pi" class="font-heading font-bold text-primary-900 text-xl mb-4">4. Propriété intellectuelle</h2>
            <p>
              L'ensemble du contenu de ce site (textes, images, logos, visuels) est la propriété exclusive de
              DMulti Services ou de ses partenaires, et est protégé par les lois françaises et internationales
              relatives à la propriété intellectuelle.
            </p>
            <p class="mt-3">
              Toute reproduction, représentation, modification, publication ou adaptation, totale ou partielle,
              des éléments du site, quel que soit le moyen ou le procédé utilisé, est interdite sans
              l'autorisation préalable et écrite de DMulti Services.
            </p>
          </section>

          <!-- 5. Responsabilité -->
          <section aria-labelledby="responsabilite">
            <h2 id="responsabilite" class="font-heading font-bold text-primary-900 text-xl mb-4">5. Limitation de responsabilité</h2>
            <p>
              Les informations contenues sur ce site sont aussi précises que possible et le site est
              régulièrement mis à jour. Cependant, DMulti Services ne peut garantir l'exactitude, la complétude
              ni l'actualité des informations. DMulti Services décline toute responsabilité pour tout dommage
              résultant de l'utilisation de ce site.
            </p>
          </section>

          <!-- 6. Données personnelles -->
          <section aria-labelledby="donnees">
            <h2 id="donnees" class="font-heading font-bold text-primary-900 text-xl mb-4">6. Données personnelles</h2>
            <p>
              Pour toute information sur la collecte et le traitement des données personnelles, veuillez consulter
              notre{' '}
              <a href="/politique-de-confidentialite" class="text-primary-700 font-medium hover:underline">
                Politique de confidentialité
              </a>.
            </p>
          </section>

          <!-- 7. Cookies -->
          <section aria-labelledby="cookies">
            <h2 id="cookies" class="font-heading font-bold text-primary-900 text-xl mb-4">7. Cookies</h2>
            <p>
              Ce site utilise Umami Analytics, un outil de mesure d'audience qui ne dépose aucun cookie
              sur votre navigateur et ne collecte aucune donnée personnelle identifiable. Aucune bannière
              de consentement n'est nécessaire.
            </p>
          </section>

          <!-- 8. Droit applicable -->
          <section aria-labelledby="droit">
            <h2 id="droit" class="font-heading font-bold text-primary-900 text-xl mb-4">8. Droit applicable et juridiction compétente</h2>
            <p>
              Les présentes mentions légales sont régies par le droit français. En cas de litige, les tribunaux
              compétents sont ceux du ressort du siège social de DMulti Services.
            </p>
          </section>

          <p class="text-xs text-neutral-400 pt-4 border-t border-neutral-100">
            Dernière mise à jour : {year}
          </p>
        </div>
      </article>

      <div class="mt-8 text-center">
        <a href="/" class="text-neutral-500 hover:text-primary-900 text-sm transition-colors">
          ← Retour à l'accueil
        </a>
      </div>
    </div>
  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
